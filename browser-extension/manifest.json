{
  "manifest_version": 3,
  "name": "PiliPlus Adaptive CDN for Web",
  "version": "0.2.4",
  "description": "Adaptive CDN scoring, buffering monitor, and MSE-preserving source switching for bilibili web playback.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.bilivideo.com/*",
    "*://*.bilivideo.cn/*",
    "*://*.akamaized.net/*"
  ],
  "action": {
    "default_title": "Adaptive CDN",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*"
      ],
      "js": ["core.js", "page.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}
